# ── Supabase ───────────────────────────────────────────────────────────
# 프로젝트 URL (Supabase 대시보드 > Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# 공개 Anon 키 (RLS가 보호함, 클라이언트 노출 허용)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# 서비스 롤 키 (서버 전용 — 절대 NEXT_PUBLIC_ 접두사 사용 금지)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site URL ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://insidespeakers.co.kr

# ── Email (Resend) ──────────────────────────────────────────────────────
# Resend API 키 (https://resend.com)
RESEND_API_KEY=re_your_resend_api_key

# 문의 알림 수신 이메일 주소 (단일 고정 주소)
NOTIFICATION_EMAIL=contact@insidecompany.co.kr

# ── ISR Revalidation ────────────────────────────────────────────────────
# /api/admin/revalidate 엔드포인트 보호용 시크릿
REVALIDATE_SECRET=your-revalidate-secret
